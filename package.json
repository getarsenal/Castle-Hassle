{
  "name": "castle-hassle",
  "version": "0.1.0",
  "private": true,
  "description": "Castle Hassle - a 2.5D medieval siege game",
  "type": "module",
  "scripts": {
    "dev": "vite --open /index.dev.html",
    "build": "vite build && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --port 4173",
    "icons": "capacitor-assets generate --ios --iconBackgroundColor '#1a2433' --iconBackgroundColorDark '#1a2433'",
    "sync": "npm run build && npx cap sync ios",
    "shoot:map": "node scripts/shoot-map.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/three": "^0.184.0",
    "puppeteer-core": "^25.1.0",
    "topojson-client": "^3.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3",
    "world-atlas": "^2.0.2"
  }
}
